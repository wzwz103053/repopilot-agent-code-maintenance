# =============================================================================
# RepoPilot Environment Example
# Copy this file to .env and fill in real values locally.
#
# IMPORTANT:
# - Do NOT commit .env to GitHub.
# - .env.example is safe to commit because it contains placeholders only.
# =============================================================================


# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Option A: OpenAI-compatible models
# Put your real key in .env, not in this file.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# Option B: DashScope / Alibaba Cloud Bailian
# Use these if your project is configured to use DashScope-compatible models.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus

# Optional generic model name fallback
MODEL_NAME=gpt-5-mini


# =============================================================================
# LangSmith / LangGraph Studio
# =============================================================================

# Set true if you want traces in LangSmith.
# Set false if you only want local running without uploading traces.
LANGSMITH_TRACING=false

# Put your real LangSmith key in .env only.
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Project name shown in LangSmith
LANGSMITH_PROJECT=repopilot

# Optional legacy compatibility
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=repopilot


# =============================================================================
# V11 Guardrails
# =============================================================================

REPOPILOT_ENABLE_GUARDRAILS=true

# Block prompt injection-like instructions in issue text or repository content.
REPOPILOT_BLOCK_PROMPT_INJECTION=true

# Redact secrets from repository content before passing it to agents.
REPOPILOT_REDACT_SECRETS=true

# Whether patch generation is allowed to modify test files.
# Recommended false for safer demo behavior.
REPOPILOT_ALLOW_TEST_FILE_PATCHES=false


# =============================================================================
# V12 Agent Middleware
# =============================================================================

REPOPILOT_ENABLE_AGENT_MIDDLEWARE=true

# PII middleware
REPOPILOT_ENABLE_PII_MIDDLEWARE=true
REPOPILOT_PII_STRATEGY=redact
REPOPILOT_PII_APPLY_TO_INPUT=true
REPOPILOT_PII_APPLY_TO_OUTPUT=true

# Current supported PII labels in your project should use "ip", not "ip_address".
REPOPILOT_PII_TYPES=email,credit_card,ip

# Human-in-the-loop middleware inside agents.
# The graph already has a human_review node, so keep this false by default.
REPOPILOT_ENABLE_HITL_MIDDLEWARE=false
REPOPILOT_HITL_ON_READ_REPO_FILE=false
REPOPILOT_HITL_ON_SEARCH_REPO_CODE=false

# Summarization middleware for long agent message histories.
REPOPILOT_ENABLE_SUMMARIZATION_MIDDLEWARE=false
REPOPILOT_SUMMARY_MAX_TOKENS_BEFORE_SUMMARY=6000
REPOPILOT_SUMMARY_MESSAGES_TO_KEEP=6


# =============================================================================
# V13 Retrieval / Agentic RAG
# =============================================================================

REPOPILOT_ENABLE_RETRIEVAL=true
REPOPILOT_RETRIEVAL_TOP_K=6
REPOPILOT_RETRIEVAL_CHUNK_SIZE=80
REPOPILOT_RETRIEVAL_CHUNK_OVERLAP=20
REPOPILOT_RETRIEVAL_MAX_CONTEXT_CHARS=6000


# =============================================================================
# V15 Issue Router
# =============================================================================

REPOPILOT_ENABLE_ISSUE_ROUTER=true

# Final version supports bug_fix and docs_update execution.
# Other routes can be detected but are not implemented yet.
REPOPILOT_SUPPORTED_ISSUE_ROUTES=bug_fix,docs_update


# =============================================================================
# V17 Patch Evaluator-Optimizer
# =============================================================================

# If true, Patch Evaluator may call an LLM after deterministic checks pass.
# If false, only deterministic patch evaluation is used.
# For stable local demos, false is safer.
REPOPILOT_ENABLE_LLM_PATCH_EVALUATOR=false

# Optional model used specifically by patch_evaluator_agent.
REPOPILOT_EVALUATOR_MODEL=gpt-5-mini

# Maximum number of times Patch Evaluator can reject and ask Patch Writer to retry.
REPOPILOT_MAX_PATCH_REVISION_ATTEMPTS=1

# Reject patches that are too large.
REPOPILOT_PATCH_EVAL_MAX_CHANGED_LINES=120


# =============================================================================
# Demo / Repair Settings
# =============================================================================

# Default repair attempts for failed tests.
REPOPILOT_DEFAULT_MAX_REPAIR_ATTEMPTS=2

# Auto approve patches in demo scripts.
# Real production use should set this to false.
REPOPILOT_AUTO_APPROVE=false